# 1. Supabase (Database, Auth, and Storage)
NEXT_PUBLIC_SUPABASE_URL=https://your-supabase-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# 2. Redis (Upstash) for Rate Limiting, Session Caching, and OAuth States
UPSTASH_REDIS_REST_URL=https://your-redis-database.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-redis-rest-token

# 3. LLM/AI APIs
GEMINI_API_KEY=your-gemini-api-key
GEMINI_EMBEDDING_KEY=your-gemini-embedding-key
TOGETHER_API_KEY=your-together-api-key
# Model used for all Together AI text features. Any Together model id works.
TOGETHER_MODEL=moonshotai/Kimi-K2.6
# Together embedding model (native 1024 dims)
TOGETHER_EMBED_MODEL=intfloat/multilingual-e5-large-instruct

# 4. Email Integration
RESEND_API_KEY=your-resend-api-key

# 5. Personalization Engine Tracking Snippet CDN URL
NEXT_PUBLIC_SNIPPET_CDN_URL=https://your-snippet-cdn-url.com

# 6. Encryption, Billing, and Cron Secrets
ENCRYPTION_KEY=your-32-byte-encryption-secret-key-here
FOUNDER_CLIENT_ID=your-supabase-auth-user-id-for-founder-account
CRON_SECRET=your-cron-secret-for-visits-reset

# 7. Lemon Squeezy Webhook Verification Secret
LEMONSQUEEZY_WEBHOOK_SECRET=your-lemonsqueezy-webhook-signing-secret

# 8. OAuth Credentials for CRMs
HUBSPOT_CLIENT_ID=your-hubspot-client-id
HUBSPOT_CLIENT_SECRET=your-hubspot-client-secret
ZOHO_CLIENT_ID=your-zoho-client-id
ZOHO_CLIENT_SECRET=your-zoho-client-secret
PIPEDRIVE_CLIENT_ID=your-pipedrive-client-id
PIPEDRIVE_CLIENT_SECRET=your-pipedrive-client-secret
CLOSE_CLIENT_ID=your-close-client-id
CLOSE_CLIENT_SECRET=your-close-client-secret
CALENDLY_CLIENT_ID=your-calendly-client-id
CALENDLY_CLIENT_SECRET=your-calendly-client-secret
